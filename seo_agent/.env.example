# ── Required ──────────────────────────────────────────────────────────
# Anthropic Claude API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ── Google APIs (optional but recommended) ────────────────────────────
# For Railway/production: paste the full JSON content of your service account key
GOOGLE_SERVICE_ACCOUNT_JSON=

# For local development: path to your service account JSON file
# GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./credentials/google_service_account.json

# Google Analytics 4 property ID (format: 123456789)
GA4_PROPERTY_ID=

# ── Ahrefs (optional) ─────────────────────────────────────────────────
AHREFS_API_KEY=

# ── WordPress auto-implementation (optional) ──────────────────────────
WP_URL=https://your-site.com
WP_USERNAME=your-wp-username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ── Model overrides (optional — defaults shown) ───────────────────────
LLM_ANALYSIS_MODEL=claude-sonnet-4-20250514
LLM_EXTRACTION_MODEL=claude-haiku-4-5-20251001
